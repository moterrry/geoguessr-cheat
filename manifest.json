{
  "manifest_version": 3,
  "name": "Geoguessr script",
  "version": "1.1",
  "description": "github.com/moterrry",
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "https://*.geoguessr.com/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.geoguessr.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://www.geoguessr.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}